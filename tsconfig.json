{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@features/*": ["src/features/*"],
      "@navigation/*": ["src/navigation/*"],
      "@services/*": ["src/services/*"],
      "@shared/*": ["src/shared/*"],
      "@store/*": ["src/store/*"],
      "@test/*": ["src/test/*"]
    }
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/test",
    "jest.setup.ts"
  ]
}
